{
  "_comment": "WP-01b placeholder template. WP-03 substitutes {{HOOK_ROOT}} and {{FIND_ROOT_SCRIPT}} with real wow-harness paths and emits the 15-row grep-locked registry to .wow-harness/MANIFEST.yaml#settings_command_registry. WP-11 installer atomically appends one PreToolUse Read|Bash matcher via python3 -c 'import json' or jq (never sed). Contract: producer = WP-01b (template), substituter = WP-03 (15 rows), consumer = WP-11 (16th row). See PLAN-086 v2.1-final section 4 phase B + patch_b.",

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$({{HOOK_ROOT}}/{{FIND_ROOT_SCRIPT}})\" && python3 {{HOOK_ROOT}}/guard-feedback.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$({{HOOK_ROOT}}/{{FIND_ROOT_SCRIPT}})\" && python3 {{HOOK_ROOT}}/deploy-guard.py"
          }
        ]
      }
    ],
    "PostToolUse": [],
    "Stop": [],
    "PreCompact": [],
    "SessionStart": [],
    "SessionEnd": []
  }
}
