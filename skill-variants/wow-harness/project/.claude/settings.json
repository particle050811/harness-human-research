{
  "attribution": {
    "co_authored_by": true,
    "co_author_name": "Claude Opus 4.6",
    "co_author_email": "noreply@anthropic.com"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(scripts/hooks/find-project-root.sh)\" && python3 scripts/guard-feedback.py",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "cd \"$(scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/loop-detection.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "cd \"$(scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/risk-tracker.py 2>/dev/null || true",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(scripts/hooks/find-project-root.sh)\" && python3 scripts/deploy-guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "if": "Bash(python *)",
            "command": "cd \"$(scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/auto-python3.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/tool-call-counter.py 2>/dev/null || true",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/review-agent-gatekeeper.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/sanitize-on-read.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(scripts/hooks/find-project-root.sh)\" && bash scripts/hooks/precompact.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/session-start-reset-risk.py",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "cd \"$(scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/session-start-magic-docs.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "cd \"$(scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/session-start-toolkit-reminder.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/stop-evaluator.py",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/session-reflection.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "cd \"$(scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/trace-analyzer.py analyze --days 1 --min-samples 3 2>/dev/null || true",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "cd \"$(scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/deploy-progress-on-session-end.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/failure-analyzer.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
